---
import Base from "../../layouts/Base.astro";
import { getAllPosts, uniqueTags, tagCounts } from "../../utils/posts";

const posts = await getAllPosts();
const tags = uniqueTags(posts);
const counts = tagCounts(posts);
---

<Base title="Tags">
  <h1 class="section-heading">Tags</h1>
  {tags.length === 0 ? (
    <p class="meta">No tags yet.</p>
  ) : (
    <ul class="tag-cloud">
      {tags.map((tag) => (
        <li>
          <a class="tag-pill" href={`/tags/${tag}/`}>
            #{tag} <span class="count">({counts.get(tag)})</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-s);
    text-decoration: none;
  }

  .tag-pill:hover {
    color: var(--color-accent-hover);
  }

  .count {
    color: var(--color-text-3);
  }
</style>
