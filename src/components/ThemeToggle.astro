---
// Three-state theme control: auto (system, default) → light → dark → auto.
// Absence of localStorage.theme = auto. Switching light↔dark plays a circle
// reveal from the button via the View Transitions API (TRD §5.4, §9.8).
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle"
  aria-label="Theme: system"
  title="Theme: system"
>
  <!-- Sun (light) -->
  <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
       aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <!-- Moon (dark) -->
  <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
       aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <!-- Monitor (auto / system) -->
  <svg class="icon-auto" width="18" height="18" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
       aria-hidden="true">
    <rect x="2" y="3" width="20" height="14" rx="2"></rect>
    <path d="M8 21h8M12 17v4"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-m);
    color: var(--color-text-2);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  /* Show the icon for the current mode. */
  .icon-sun,
  .icon-moon,
  .icon-auto {
    display: none;
  }
  :global(:root[data-theme-mode="light"]) .icon-sun {
    display: block;
  }
  :global(:root[data-theme-mode="dark"]) .icon-moon {
    display: block;
  }
  :global(:root[data-theme-mode="auto"]) .icon-auto {
    display: block;
  }
</style>

<script>
  const btn = document.getElementById("theme-toggle");
  const root = document.documentElement;
  const mql = matchMedia("(prefers-color-scheme: dark)");
  const ORDER = ["auto", "light", "dark"] as const;
  type Mode = (typeof ORDER)[number];
  const LABEL: Record<Mode, string> = {
    auto: "Theme: system",
    light: "Theme: light",
    dark: "Theme: dark",
  };

  const isDark = (mode: Mode) => mode === "dark" || (mode === "auto" && mql.matches);

  function apply(mode: Mode) {
    if (mode === "auto") localStorage.removeItem("theme");
    else localStorage.setItem("theme", mode);
    root.dataset.themeMode = mode;
    root.classList.toggle("dark", isDark(mode));
    btn?.setAttribute("aria-label", LABEL[mode]);
    btn?.setAttribute("title", LABEL[mode]);
  }

  btn?.addEventListener("click", () => {
    const current = (root.dataset.themeMode as Mode) || "auto";
    const next = ORDER[(ORDER.indexOf(current) + 1) % ORDER.length];
    const visualChange = isDark(next) !== isDark(current);
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const startVT = (document as any).startViewTransition?.bind(document);

    // No visible change (e.g. auto→light while system is light), reduced motion,
    // or no View Transitions support → switch instantly.
    if (!visualChange || reduce || !startVT) {
      apply(next);
      return;
    }

    const r = btn.getBoundingClientRect();
    const bx = r.left + r.width / 2;
    const by = r.top + r.height / 2;
    const radius = Math.hypot(
      Math.max(bx, innerWidth - bx),
      Math.max(by, innerHeight - by),
    );

    root.classList.add("vt-active");
    const tr = startVT(() => apply(next));
    tr.ready.then(() => {
      root.animate(
        {
          clipPath: [
            `circle(0px at ${bx}px ${by}px)`,
            `circle(${radius}px at ${bx}px ${by}px)`,
          ],
        },
        {
          duration: 500,
          easing: "ease-in-out",
          pseudoElement: "::view-transition-new(root)",
        },
      );
    });
    tr.finished.finally(() => root.classList.remove("vt-active"));
  });
</script>
