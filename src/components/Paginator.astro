---
interface Props {
  prevUrl?: string;
  nextUrl?: string;
  currentPage: number;
  lastPage: number;
}

const { prevUrl, nextUrl, currentPage, lastPage } = Astro.props;
---

{lastPage > 1 && (
  <nav class="paginator" aria-label="Pagination">
    <div class="side">
      {prevUrl ? <a href={prevUrl} rel="prev">← Newer</a> : <span />}
    </div>
    <span class="indicator">Page {currentPage} of {lastPage}</span>
    <div class="side end">
      {nextUrl ? <a href={nextUrl} rel="next">Older →</a> : <span />}
    </div>
  </nav>
)}

<style>
  .paginator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-12);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .side {
    flex: 1;
  }

  .side.end {
    text-align: right;
  }

  .paginator a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .paginator a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .indicator {
    color: var(--color-text-3);
  }
</style>
