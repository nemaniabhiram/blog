---
// Easter egg: an animated ASCII wave rendered with Telugu letters (TRD §11).
// Behaviour E1–E12. RAMP/ALPHABET come from the single source in data/telugu.
---

<div class="wave-wrap">
  <canvas id="telugu-wave" aria-hidden="true"></canvas>
  <span class="visually-hidden">Decorative animated wave of Telugu letters</span>
</div>

<style>
  .wave-wrap {
    width: 100%;
  }

  #telugu-wave {
    display: block;
    width: 100%;
    height: 112px;
  }

  @media (max-width: 639px) {
    #telugu-wave {
      height: 88px;
    }
  }
</style>

<script>
  import { RAMP, ALPHABET } from "../data/telugu";

  const canvas = document.getElementById("telugu-wave") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const CELL_W = 16,
      CELL_H = 18,
      FPS = 24, // smooth positional glide (calm = low velocity, not low fps) (E6)
      FONT = "14px 'Noto Sans Telugu', monospace";
    // v5 — v1/v2's ambient density field (airy near the surface, denser with
    // depth, letters cresting on peaks, spray) but with v4's sub-pixel gliding
    // motion, and slowed right down so it feels calm. Every glyph is anchored to
    // a gently travelling surface; the body is a breathing RAMP texture with real
    // gaps (never a solid slab — that reads as terrain). (E4, reworked v5)
    const WAVE_BASE = 0.4, // mean water level (fraction of H, 0 = top)
      WAVE_AMP = 0.2, // crest/trough amplitude — visible, but a broad body below
      WAVE_K = 0.16, // angular frequency per column → ~1.1 gentle waves across
      WAVE_SPEED = 0.3, // phase velocity ≈ 30px/s — a crest takes ~20s to cross
      SWELL_AMP = 0.05, // slow secondary swell that breathes the whole line
      SWELL_K = 0.06,
      SWELL_SPEED = 0.12,
      DRIFT = 0.5; // columns/sec the letters drift along the water (barely there)
    // Pointer ripple: a gentle swell toward the cursor (E10)
    const RIPPLE_MS = 1500,
      RIPPLE_LIFT = 0.12, // fraction of height the water bulges up (soft)
      RIPPLE_SIGMA = 2600; // px² spread of the bulge
    // Softly-rounded wave profile (Stokes-ish): sharper crest, flatter trough.
    const stokes = (th: number) => (Math.cos(th) + 0.22 * Math.cos(2 * th)) / 1.22;
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    let cols = 0,
      rows = 0,
      seeds: string[] = [],
      seedRand: number[] = [],
      accent = "#1F1D1A";
    let t = 0,
      last = 0,
      running = false,
      raf = 0;
    let ripple = { x: -1e4, y: -1e4, until: 0 };

    const readAccent = () =>
      (accent =
        getComputedStyle(document.documentElement)
          .getPropertyValue("--color-accent")
          .trim() || accent);

    // Recolour instantly on theme toggle (E5)
    new MutationObserver(readAccent).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    function size() {
      const dpr = Math.min(devicePixelRatio || 1, 2);
      const w = canvas!.clientWidth,
        h = canvas!.clientHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(w / CELL_W);
      rows = Math.ceil(h / CELL_H) + 2; // depth bands (headroom for high crests)
      // Stable letters per cell so crest words & maxed-out ramp cells don't churn.
      seeds = Array.from(
        { length: cols * rows },
        () => ALPHABET[(Math.random() * ALPHABET.length) | 0],
      );
      // Stable per-column randomness so spray dots don't flicker frame-to-frame.
      seedRand = Array.from({ length: cols }, () => Math.random());
      readAccent();
    }

    function frame(now: number) {
      raf = requestAnimationFrame(frame);
      if (now - last < 1000 / FPS) return; // fps throttle (E6)
      t += (now - last) / 1000;
      last = now;
      const W = canvas!.clientWidth,
        H = canvas!.clientHeight;
      ctx!.clearRect(0, 0, W, H);
      ctx!.font = FONT;
      ctx!.textBaseline = "middle";
      ctx!.textAlign = "center";
      ctx!.fillStyle = accent;

      const rippleGain = ripple.until > now ? (ripple.until - now) / RIPPLE_MS : 0;
      const scroll = Math.round(t * DRIFT); // slow horizontal drift (whole cols)

      for (let x = 0; x < cols; x++) {
        const cx = x * CELL_W + CELL_W / 2;

        // Gently travelling surface (one soft wave + a slower swell), sub-pixel.
        const s = stokes(x * WAVE_K - t * WAVE_SPEED); // +1 crest … −0.54 trough
        let surfFrac =
          WAVE_BASE - WAVE_AMP * s - SWELL_AMP * Math.sin(x * SWELL_K + t * SWELL_SPEED);
        if (rippleGain > 0) {
          const dx = cx - ripple.x; // pointer swells the water toward the cursor
          surfFrac -= RIPPLE_LIFT * rippleGain * Math.exp(-(dx * dx) / RIPPLE_SIGMA);
        }
        const surfPx = surfFrac * H;
        const crestness = (s + 0.54) / 1.54; // 0 at trough → 1 at crest
        const wc = (((x - scroll) % cols) + cols) % cols; // drift-scrolled column

        // Sparse spray dots above the crests (v2).
        if (crestness > 0.7 && seedRand[wc] < 0.5) {
          const sy = surfPx - CELL_H * 0.9;
          if (sy > -CELL_H) {
            ctx!.globalAlpha = 0.18;
            ctx!.fillText("·", cx, sy);
          }
        }

        // Water body: glyphs anchored to the surface (v4 glide), rendered as
        // v1/v2's density field — airy ramp near the surface with real gaps,
        // denser with depth, plus a slow per-cell shimmer so it breathes.
        let k = 0;
        for (let py = surfPx; py < H + CELL_H * 0.5; py += CELL_H, k++) {
          const seedIdx = (k % rows) * cols + wc;
          let v: number;
          let ch: string;
          if (k === 0) {
            // Crest band: real letters riding the peaks (the v1/v2 magic).
            v = 0.5 + 0.45 * crestness;
            ch = seeds[seedIdx];
          } else {
            const depth = Math.min(1, (py - surfPx) / (H - surfPx + 1));
            // Slow twinkle (~10–15s character) — v1's living field, no jitter.
            const shimmer =
              0.16 * Math.sin(x * 0.5 + t * 0.4) * Math.sin(k * 0.9 - t * 0.25);
            v = 0.16 + 0.5 * depth + shimmer;
            if (v < 0.14) continue; // real gaps → airy texture, never a slab
            v = Math.min(1, v);
            ch = v > 0.8 ? seeds[seedIdx] : RAMP[(v * (RAMP.length - 1)) | 0];
          }
          ctx!.globalAlpha = v * 0.85 + 0.05; // (E5)
          ctx!.fillText(ch, cx, py);
        }
      }
      ctx!.globalAlpha = 1;
    }

    const start = () => {
      if (!running && !reduced) {
        running = true;
        last = performance.now();
        raf = requestAnimationFrame(frame);
      }
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    function begin() {
      size();
      if (reduced) {
        // One static frame, no loop (E7). Font is ready here, so no tofu.
        last = performance.now();
        frame(last + 1000);
        cancelAnimationFrame(raf);
        return;
      }
      // Pause when off-screen (E8)
      new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop())).observe(
        canvas!,
      );
      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : start(),
      );
    }

    // Canvas fillText can't use a web font that hasn't loaded yet, and it does
    // not auto-redraw when one arrives — so wait for Noto Sans Telugu before the
    // first draw, or the glyphs render as tofu (critical for the single
    // reduced-motion frame, which never redraws). (E2/E7, TRD §17)
    const fontReady =
      "fonts" in document
        ? (document as Document).fonts.load("14px 'Noto Sans Telugu'").catch(() => {})
        : Promise.resolve();
    fontReady.then(begin);

    // Debounced re-init on resize (E9)
    let resizeId = 0;
    addEventListener("resize", () => {
      clearTimeout(resizeId);
      resizeId = window.setTimeout(size, 150);
    });

    // Pointer / touch ripple (E10)
    canvas.addEventListener("pointermove", (e) => {
      const r = canvas.getBoundingClientRect();
      ripple = {
        x: e.clientX - r.left,
        y: e.clientY - r.top,
        until: performance.now() + 1500,
      };
    });

    // Console easter egg (E11)
    console.log(
      "%cనమస్కారం 🌊 — built with Astro by Abhiram Nemani. Source: https://github.com/nemaniabhiram/blog",
      "color:#B3AEA3;font-size:13px",
    );
  }
</script>
