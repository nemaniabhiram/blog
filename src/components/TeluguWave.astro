---
// Easter egg: an animated ASCII wave rendered with Telugu letters (TRD §11).
// Behaviour E1–E12. RAMP/ALPHABET come from the single source in data/telugu.
---

<div class="wave-wrap">
  <canvas id="telugu-wave" aria-hidden="true"></canvas>
  <span class="visually-hidden">Decorative animated wave of Telugu letters</span>
</div>

<style>
  .wave-wrap {
    width: 100%;
  }

  #telugu-wave {
    display: block;
    width: 100%;
    height: 112px;
  }

  @media (max-width: 639px) {
    #telugu-wave {
      height: 88px;
    }
  }
</style>

<script>
  import { RAMP, ALPHABET } from "../data/telugu";

  const canvas = document.getElementById("telugu-wave") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const CELL_W = 16,
      CELL_H = 18,
      FPS = 24, // positional motion needs more frames than the old 12 (E6)
      FONT = "14px 'Noto Sans Telugu', monospace";
    // Rolling-water tuning. The surface is a smooth travelling line (two
    // interfering sines + a slow swell); glyphs are *anchored* to it with
    // sub-pixel positioning, so the whole letter-mass rises and falls smoothly
    // as crests roll left→right — no grid snapping / popping. (E4, reworked v3)
    const SURF_BASE = 0.42, // mean water level (fraction of height, 0 = top)
      SURF_AMP = 0.15, // crest amplitude
      SURF_FREQ = 0.2, // primary crest frequency (columns)
      SURF_SPEED = 1.1, // primary crest travel speed (left → right)
      SURF_FREQ2 = 0.31, // secondary wave (interference → organic crests)
      SURF_SPEED2 = 0.7,
      SWELL_AMP = 0.05, // slow bulk swell that rolls the whole surface
      SWELL_FREQ = 0.07,
      SWELL_SPEED = 0.35,
      DRIFT = 2.4, // horizontal current: columns/sec the letter field flows →
      SPRAY_ROWS = 2; // rows of spray dots above the crest
    // Pointer ripple lifts the surface toward the cursor (E10)
    const RIPPLE_MS = 1500,
      RIPPLE_LIFT = 0.2, // fraction of height the water bulges up
      RIPPLE_SIGMA = 2600; // px² spread of the bulge
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    let cols = 0,
      rows = 0,
      bands = 0,
      seeds: string[] = [],
      seedRand: number[] = [],
      accent = "#C15F3C";
    let t = 0,
      last = 0,
      running = false,
      raf = 0;
    let ripple = { x: -1e4, y: -1e4, until: 0 };

    const readAccent = () =>
      (accent =
        getComputedStyle(document.documentElement)
          .getPropertyValue("--color-accent")
          .trim() || accent);

    // Recolour instantly on theme toggle (E5)
    new MutationObserver(readAccent).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    function size() {
      const dpr = Math.min(devicePixelRatio || 1, 2);
      const w = canvas!.clientWidth,
        h = canvas!.clientHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(w / CELL_W);
      rows = Math.ceil(h / CELL_H);
      bands = rows + 3; // depth rows in the anchored stack (a little headroom)
      seeds = Array.from(
        { length: cols * bands },
        () => ALPHABET[(Math.random() * ALPHABET.length) | 0],
      );
      // Stable per-column randomness so spray dots don't flicker frame-to-frame.
      seedRand = Array.from({ length: cols * bands }, () => Math.random());
      readAccent();
    }

    function frame(now: number) {
      raf = requestAnimationFrame(frame);
      if (now - last < 1000 / FPS) return; // fps throttle (E6)
      t += (now - last) / 1000;
      last = now;
      const W = canvas!.clientWidth,
        H = canvas!.clientHeight;
      ctx!.clearRect(0, 0, W, H);
      ctx!.font = FONT;
      ctx!.textBaseline = "middle";
      ctx!.textAlign = "center";
      ctx!.fillStyle = accent;

      const rippleGain = ripple.until > now ? (ripple.until - now) / RIPPLE_MS : 0;
      const drift = Math.floor(t * DRIFT); // horizontal current (whole columns)

      for (let x = 0; x < cols; x++) {
        const cx = x * CELL_W + CELL_W / 2;

        // Smooth travelling surface, in px. Two interfering sines make the
        // crests organic; a slow swell rolls the whole line.
        const s1 = Math.sin(x * SURF_FREQ - t * SURF_SPEED);
        const s2 = Math.sin(x * SURF_FREQ2 + t * SURF_SPEED2 + 1.7);
        const swell = Math.sin(x * SWELL_FREQ + t * SWELL_SPEED);
        let surfF = SURF_BASE - SURF_AMP * (0.6 * s1 + 0.4 * s2) - SWELL_AMP * swell;
        if (rippleGain > 0) {
          const dx = cx - ripple.x; // pointer lifts the water toward the cursor
          surfF -= RIPPLE_LIFT * rippleGain * Math.exp(-(dx * dx) / RIPPLE_SIGMA);
        }
        const surfPx = surfF * H;

        // Column of stable randomness for spray/among cells, scrolled by current.
        const src = (((x - drift) % cols) + cols) % cols;

        // Spray dots riding above the crest.
        for (let s = 1; s <= SPRAY_ROWS; s++) {
          const sy = surfPx - s * CELL_H * 0.85;
          if (sy < -CELL_H) break;
          if (seedRand[s * cols + src] < 0.5 - s * 0.16) {
            ctx!.globalAlpha = 0.2 - s * 0.06;
            ctx!.fillText("·", cx, sy);
          }
        }

        // Water body: glyphs anchored to the surface, stacked to the bottom.
        // Sub-pixel `py` → the mass slides smoothly as the surface bobs; letters
        // ride the wave (identity keyed by depth band + drift, so they don't
        // churn while bobbing) and flow sideways with the current.
        let k = 0;
        for (let py = surfPx; py < H + CELL_H * 0.5; py += CELL_H, k++) {
          const df = (py - surfPx) / Math.max(1, H - surfPx); // 0 surface → 1 floor
          let v = k === 0 ? 0.92 : 0.35 + 0.62 * df; // crest foam brightest
          v = Math.min(1, Math.max(0, v));
          if (v < 0.1) continue;
          const seedIdx = ((k % bands) + bands) % bands * cols + src;
          // Bright cells (crest + deep water) carry real Telugu letters; the
          // shallow fade uses the density ramp (E3).
          const ch = v > 0.78 ? seeds[seedIdx] : RAMP[(v * (RAMP.length - 1)) | 0];
          ctx!.globalAlpha = v * 0.85 + 0.05; // (E5)
          ctx!.fillText(ch, cx, py);
        }
      }
      ctx!.globalAlpha = 1;
    }

    const start = () => {
      if (!running && !reduced) {
        running = true;
        last = performance.now();
        raf = requestAnimationFrame(frame);
      }
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    function begin() {
      size();
      if (reduced) {
        // One static frame, no loop (E7). Font is ready here, so no tofu.
        last = performance.now();
        frame(last + 1000);
        cancelAnimationFrame(raf);
        return;
      }
      // Pause when off-screen (E8)
      new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop())).observe(
        canvas!,
      );
      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : start(),
      );
    }

    // Canvas fillText can't use a web font that hasn't loaded yet, and it does
    // not auto-redraw when one arrives — so wait for Noto Sans Telugu before the
    // first draw, or the glyphs render as tofu (critical for the single
    // reduced-motion frame, which never redraws). (E2/E7, TRD §17)
    const fontReady =
      "fonts" in document
        ? (document as Document).fonts.load("14px 'Noto Sans Telugu'").catch(() => {})
        : Promise.resolve();
    fontReady.then(begin);

    // Debounced re-init on resize (E9)
    let resizeId = 0;
    addEventListener("resize", () => {
      clearTimeout(resizeId);
      resizeId = window.setTimeout(size, 150);
    });

    // Pointer / touch ripple (E10)
    canvas.addEventListener("pointermove", (e) => {
      const r = canvas.getBoundingClientRect();
      ripple = {
        x: e.clientX - r.left,
        y: e.clientY - r.top,
        until: performance.now() + 1500,
      };
    });

    // Console easter egg (E11)
    console.log(
      "%cనమస్కారం 🌊 — built with Astro by Abhiram Nemani. Source: https://github.com/nemaniabhiram/blog",
      "color:#D97757;font-size:13px",
    );
  }
</script>
