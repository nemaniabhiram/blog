---
// Easter egg: an animated ASCII wave rendered with Telugu letters (TRD §11).
// Behaviour E1–E12. RAMP/ALPHABET come from the single source in data/telugu.
---

<div class="wave-wrap">
  <canvas id="telugu-wave" aria-hidden="true"></canvas>
  <span class="visually-hidden">Decorative animated wave of Telugu letters</span>
</div>

<style>
  .wave-wrap {
    width: 100%;
  }

  #telugu-wave {
    display: block;
    width: 100%;
    height: 112px;
  }

  @media (max-width: 639px) {
    #telugu-wave {
      height: 88px;
    }
  }
</style>

<script>
  import { ALPHABET } from "../data/telugu";

  const canvas = document.getElementById("telugu-wave") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const CELL_W = 16,
      CELL_H = 18,
      FPS = 24, // smooth positional motion (E6)
      FONT = "14px 'Noto Sans Telugu', monospace";
    // v4 — glyph ribbons on ONE dominant travelling Stokes wave. The wave is a
    // thick ribbon of letters tracing a sharp-crested / flat-troughed curve over
    // mostly open space, with faint echo ribbons behind it (parallax). The curve
    // *is* the wave — a filled mass just reads as terrain. (E4, reworked v4)
    const WAVE_BASE = 0.42, // mean line height (fraction of canvas H, 0 = top)
      WAVE_AMP = 0.32, // amplitude (fraction of H) — large, uses most of the strip
      WAVE_K = 0.17, // angular frequency per column → ~1.1 waves across (one big wave)
      WAVE_SPEED = 1.4, // crest travel speed (left → right)
      RIBBON = 3, // primary ribbon thickness (glyph on the curve + 2 below)
      DRIFT = 3; // columns/sec the letters ride along the wave →
    // Echo ribbons behind the primary (depth / parallax).
    const ECHOES = [
      { amp: 0.62, phase: 2.1, speed: 0.8, alpha: 0.32, off: 11 },
      { amp: 0.42, phase: 4.2, speed: 0.62, alpha: 0.18, off: 22 },
    ];
    const SEED_ROWS = RIBBON + ECHOES.length;
    // Pointer ripple lifts the primary crest toward the cursor (E10)
    const RIPPLE_MS = 1500,
      RIPPLE_LIFT = 0.18, // fraction of height the water bulges up
      RIPPLE_SIGMA = 2600; // px² spread of the bulge
    // Sharp-crested Stokes profile: cos + a 2nd harmonic sharpens crests and
    // flattens troughs. Returns ~ +1 (crest) … −0.54 (trough).
    const stokes = (th: number) => (Math.cos(th) + 0.3 * Math.cos(2 * th)) / 1.3;
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    let cols = 0,
      seeds: string[] = [],
      seedRand: number[] = [],
      accent = "#C15F3C";
    let t = 0,
      last = 0,
      running = false,
      raf = 0;
    let ripple = { x: -1e4, y: -1e4, until: 0 };

    const readAccent = () =>
      (accent =
        getComputedStyle(document.documentElement)
          .getPropertyValue("--color-accent")
          .trim() || accent);

    // Recolour instantly on theme toggle (E5)
    new MutationObserver(readAccent).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    function size() {
      const dpr = Math.min(devicePixelRatio || 1, 2);
      const w = canvas!.clientWidth,
        h = canvas!.clientHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(w / CELL_W);
      // One drifting strip of letters per ribbon row (primary rows + echoes).
      seeds = Array.from(
        { length: cols * SEED_ROWS },
        () => ALPHABET[(Math.random() * ALPHABET.length) | 0],
      );
      // Stable per-column randomness so spray dots don't flicker frame-to-frame.
      seedRand = Array.from({ length: cols }, () => Math.random());
      readAccent();
    }

    function frame(now: number) {
      raf = requestAnimationFrame(frame);
      if (now - last < 1000 / FPS) return; // fps throttle (E6)
      t += (now - last) / 1000;
      last = now;
      const W = canvas!.clientWidth,
        H = canvas!.clientHeight;
      ctx!.clearRect(0, 0, W, H);
      ctx!.font = FONT;
      ctx!.textBaseline = "middle";
      ctx!.textAlign = "center";
      ctx!.fillStyle = accent;

      const rippleGain = ripple.until > now ? (ripple.until - now) / RIPPLE_MS : 0;
      const scroll = Math.round(t * DRIFT); // letters ride the wave → (whole cols)

      // Echo ribbons first (behind): thin single-glyph lines at reduced
      // amplitude, phase and speed for parallax depth.
      for (let e = 0; e < ECHOES.length; e++) {
        const ec = ECHOES[e];
        const phase = t * WAVE_SPEED * ec.speed + ec.phase;
        ctx!.globalAlpha = ec.alpha;
        for (let x = 0; x < cols; x++) {
          const y = (WAVE_BASE - WAVE_AMP * ec.amp * stokes(x * WAVE_K - phase)) * H + ec.off;
          if (y < -CELL_H || y > H + CELL_H) continue;
          const wc = (((x - scroll) % cols) + cols) % cols;
          ctx!.fillText(seeds[(RIBBON + e) * cols + wc], x * CELL_W + CELL_W / 2, y);
        }
      }

      // Primary ribbon (front): a thick band of letters on the dominant wave.
      for (let x = 0; x < cols; x++) {
        const cx = x * CELL_W + CELL_W / 2;
        const s = stokes(x * WAVE_K - t * WAVE_SPEED);
        let yFrac = WAVE_BASE - WAVE_AMP * s;
        if (rippleGain > 0) {
          const dx = cx - ripple.x; // pointer lifts the crest toward the cursor
          yFrac -= RIPPLE_LIFT * rippleGain * Math.exp(-(dx * dx) / RIPPLE_SIGMA);
        }
        const y0 = yFrac * H;
        const crestness = (s + 0.538) / 1.538; // 0 at trough → 1 at crest
        const wc = (((x - scroll) % cols) + cols) % cols;

        // Spray riding off the sharp crests.
        if (crestness > 0.72 && seedRand[wc] < 0.5) {
          const sy = y0 - CELL_H * 0.9;
          if (sy > -CELL_H) {
            ctx!.globalAlpha = 0.22;
            ctx!.fillText("·", cx, sy);
          }
        }

        for (let r = 0; r < RIBBON; r++) {
          const py = y0 + r * CELL_H;
          if (py > H + CELL_H) break;
          if (py < -CELL_H) continue;
          const rowA = r === 0 ? 1 : r === 1 ? 0.5 : 0.26; // fade downward
          ctx!.globalAlpha = rowA * (0.55 + 0.45 * crestness); // crest brighter
          ctx!.fillText(seeds[r * cols + wc], cx, py);
        }
      }
      ctx!.globalAlpha = 1;
    }

    const start = () => {
      if (!running && !reduced) {
        running = true;
        last = performance.now();
        raf = requestAnimationFrame(frame);
      }
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    function begin() {
      size();
      if (reduced) {
        // One static frame, no loop (E7). Font is ready here, so no tofu.
        last = performance.now();
        frame(last + 1000);
        cancelAnimationFrame(raf);
        return;
      }
      // Pause when off-screen (E8)
      new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop())).observe(
        canvas!,
      );
      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : start(),
      );
    }

    // Canvas fillText can't use a web font that hasn't loaded yet, and it does
    // not auto-redraw when one arrives — so wait for Noto Sans Telugu before the
    // first draw, or the glyphs render as tofu (critical for the single
    // reduced-motion frame, which never redraws). (E2/E7, TRD §17)
    const fontReady =
      "fonts" in document
        ? (document as Document).fonts.load("14px 'Noto Sans Telugu'").catch(() => {})
        : Promise.resolve();
    fontReady.then(begin);

    // Debounced re-init on resize (E9)
    let resizeId = 0;
    addEventListener("resize", () => {
      clearTimeout(resizeId);
      resizeId = window.setTimeout(size, 150);
    });

    // Pointer / touch ripple (E10)
    canvas.addEventListener("pointermove", (e) => {
      const r = canvas.getBoundingClientRect();
      ripple = {
        x: e.clientX - r.left,
        y: e.clientY - r.top,
        until: performance.now() + 1500,
      };
    });

    // Console easter egg (E11)
    console.log(
      "%cనమస్కారం 🌊 — built with Astro by Abhiram Nemani. Source: https://github.com/nemaniabhiram/blog",
      "color:#D97757;font-size:13px",
    );
  }
</script>
