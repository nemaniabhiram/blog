---
// Easter egg: an animated ASCII wave rendered with Telugu letters (TRD §11).
// Behaviour E1–E12. RAMP/ALPHABET come from the single source in data/telugu.
---

<div class="wave-wrap">
  <canvas id="telugu-wave" aria-hidden="true"></canvas>
  <span class="visually-hidden">Decorative animated wave of Telugu letters</span>
</div>

<style>
  .wave-wrap {
    width: 100%;
  }

  #telugu-wave {
    display: block;
    width: 100%;
    height: 112px;
  }

  @media (max-width: 639px) {
    #telugu-wave {
      height: 88px;
    }
  }
</style>

<script>
  import { RAMP, ALPHABET } from "../data/telugu";

  const canvas = document.getElementById("telugu-wave") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const CELL_W = 16,
      CELL_H = 18,
      FONT = "14px 'Noto Sans Telugu', monospace";
    // Surf-silhouette tuning: a travelling water surface line with pointed
    // crests and long troughs; glyphs fill the water below it (E4, reworked).
    const SURF_BASE = 0.52, // baseline surface height (fraction from top)
      SURF_AMP = 0.34, // crest rise above baseline
      SURF_SHARP = 3, // crest pointiness (higher = sharper peaks, flatter troughs)
      SURF_FREQ = 0.28, // crest spatial frequency (~2–3 crests across the column)
      SURF_SPEED = 0.8, // crest travel speed (left → right)
      SWELL_AMP = 0.08, // slow background swell that rolls the whole surface
      SWELL_FREQ = 0.09,
      SWELL_SPEED = 0.4,
      SPRAY_BAND = 0.16, // how far above the surface spray dots reach (fraction)
      CREST_BAND = 0.16; // water band just under the surface that shows letters
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    let cols = 0,
      rows = 0,
      seeds: string[] = [],
      seedRand: number[] = [],
      accent = "#C15F3C";
    let t = 0,
      last = 0,
      running = false,
      raf = 0;
    let ripple = { x: -1e4, y: -1e4, until: 0 };

    const readAccent = () =>
      (accent =
        getComputedStyle(document.documentElement)
          .getPropertyValue("--color-accent")
          .trim() || accent);

    // Recolour instantly on theme toggle (E5)
    new MutationObserver(readAccent).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    function size() {
      const dpr = Math.min(devicePixelRatio || 1, 2);
      const w = canvas!.clientWidth,
        h = canvas!.clientHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(w / CELL_W);
      rows = Math.ceil(h / CELL_H);
      seeds = Array.from(
        { length: cols * rows },
        () => ALPHABET[(Math.random() * ALPHABET.length) | 0],
      );
      // Stable per-cell randomness so spray dots don't flicker frame-to-frame;
      // the moving surface passes through this fixed field.
      seedRand = Array.from({ length: cols * rows }, () => Math.random());
      readAccent();
    }

    function frame(now: number) {
      raf = requestAnimationFrame(frame);
      if (now - last < 1000 / 12) return; // 12 fps throttle (E6)
      t += (now - last) / 1000;
      last = now;
      ctx!.clearRect(0, 0, canvas!.clientWidth, canvas!.clientHeight);
      ctx!.font = FONT;
      ctx!.textBaseline = "middle";
      ctx!.textAlign = "center";
      const rippleGain = ripple.until > now ? (ripple.until - now) / 1500 : 0;
      for (let x = 0; x < cols; x++) {
        // Surface height for this column (fraction of height, 0 = top). The
        // cubed half-sine gives narrow pointed crests over long flat troughs —
        // a rolling surf profile — travelling left → right; a slow swell adds body.
        const crest = Math.pow(
          (1 + Math.sin(x * SURF_FREQ - t * SURF_SPEED)) / 2,
          SURF_SHARP,
        );
        const swell = Math.sin(x * SWELL_FREQ + t * SWELL_SPEED);
        const surf = SURF_BASE - SURF_AMP * crest - SWELL_AMP * swell;

        for (let y = 0; y < rows; y++) {
          const i = y * cols + x;
          const fy = (y + 0.5) / rows;
          const d = fy - surf; // depth below the surface line (negative = air)
          let v: number;
          let ch: string;

          if (d < -SPRAY_BAND) {
            continue; // air, well above the surface
          } else if (d < 0) {
            // Spray just above the surface — sparse dots, denser over crests
            if (seedRand[i] >= 0.12 + 0.5 * crest) continue;
            v = 0.16 + 0.14 * crest;
            ch = "·";
          } else {
            // Water: brighter/denser with depth (E4)
            v = 0.28 + d * 1.7;
            if (rippleGain > 0) {
              const dx = x * CELL_W - ripple.x,
                dy = y * CELL_H - ripple.y;
              v += 0.6 * rippleGain * Math.exp(-(dx * dx + dy * dy) / 900); // (E10)
            }
            v = Math.min(1, Math.max(0, v));
            if (v < 0.12) continue;
            // The crest face (top band of water) and bright cells carry real
            // Telugu letters — the "foam" of words riding the wave (E3).
            ch = d < CREST_BAND || v > 0.82 ? seeds[i] : RAMP[(v * (RAMP.length - 1)) | 0];
          }

          ctx!.globalAlpha = v * 0.85 + 0.05; // (E5)
          ctx!.fillStyle = accent;
          ctx!.fillText(ch, x * CELL_W + CELL_W / 2, y * CELL_H + CELL_H / 2);
        }
      }
      ctx!.globalAlpha = 1;
    }

    const start = () => {
      if (!running && !reduced) {
        running = true;
        last = performance.now();
        raf = requestAnimationFrame(frame);
      }
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    function begin() {
      size();
      if (reduced) {
        // One static frame, no loop (E7). Font is ready here, so no tofu.
        last = performance.now();
        frame(last + 1000);
        cancelAnimationFrame(raf);
        return;
      }
      // Pause when off-screen (E8)
      new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop())).observe(
        canvas!,
      );
      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : start(),
      );
    }

    // Canvas fillText can't use a web font that hasn't loaded yet, and it does
    // not auto-redraw when one arrives — so wait for Noto Sans Telugu before the
    // first draw, or the glyphs render as tofu (critical for the single
    // reduced-motion frame, which never redraws). (E2/E7, TRD §17)
    const fontReady =
      "fonts" in document
        ? (document as Document).fonts.load("14px 'Noto Sans Telugu'").catch(() => {})
        : Promise.resolve();
    fontReady.then(begin);

    // Debounced re-init on resize (E9)
    let resizeId = 0;
    addEventListener("resize", () => {
      clearTimeout(resizeId);
      resizeId = window.setTimeout(size, 150);
    });

    // Pointer / touch ripple (E10)
    canvas.addEventListener("pointermove", (e) => {
      const r = canvas.getBoundingClientRect();
      ripple = {
        x: e.clientX - r.left,
        y: e.clientY - r.top,
        until: performance.now() + 1500,
      };
    });

    // Console easter egg (E11)
    console.log(
      "%cనమస్కారం 🌊 — built with Astro by Nemani Abhiram. Source: https://github.com/nemaniabhiram/blog",
      "color:#D97757;font-size:13px",
    );
  }
</script>
